# SpriteFlow 环境变量配置
# 复制此文件为 .env 并填入实际值

# 腾讯云 COS 配置
COS_SECRET_ID=your_cos_secret_id
COS_SECRET_KEY=your_cos_secret_key
COS_BUCKET=spriteflow-1258748206
COS_REGION=ap-guangzhou

# 火山方舟 (Seedream 5.0 Lite)
ARK_API_KEY=your_ark_api_key
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDREAM_MODEL=doubao-seedream-5-0-260128

# 火山引擎 AI 图像处理（即梦 Inpainting / 图像增强 / 抠图等）
VOLC_ACCESS_KEY_ID=your_volc_access_key_id
VOLC_SECRET_ACCESS_KEY=your_volc_secret_access_key

# OpenRouter 多模型统一入口
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_DEFAULT_MODEL=openai/gpt-image-1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Real-ESRGAN 超分工具
REALESRGAN_BIN=tools/realesrgan-ncnn-vulkan
REALESRGAN_MODEL_DIR=tools/models

# 本地配置
DATABASE_PATH=data/assets.db
CACHE_DIR=.cache
COMPONENTS_TEMP_DIR=.cache/components_temp
